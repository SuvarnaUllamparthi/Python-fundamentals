# Ask the user to enter their age
age = int(input("Enter your age: "))

# Voting eligibility threshold is typically 18
if age >= 18:
    print("You are eligible to vote!")
else:
    years_left = 18 - age
    print(f"You are not eligible to vote yet. You can vote in {years_left} year(s).")


