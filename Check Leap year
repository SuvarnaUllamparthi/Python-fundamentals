def checkYear(n):
  
    # Check if n is divisible by 4
    if n % 4 == 0:
      
        # If it's divisible by 100, it should also be 
        # divisible by 400 to be a leap year
        if n % 100 == 0:
            return n % 400 == 0
        return True
    return False

if __name__ == "__main__":
  year = 2000
  if checkYear(year):
      print("true")
  else:
      print("false") 

